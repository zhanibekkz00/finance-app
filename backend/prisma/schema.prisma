// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =========================
// 1. Пользователи
// =========================

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  displayName  String?   @map("display_name")
  avatarUrl    String?   @map("avatar_url")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz(6)
  role         String    @default("user")
  isBlocked    Boolean   @default(false) @map("is_blocked")

  // Groups
  groupId      String?   @map("group_id") @db.Uuid
  group        Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // Relations
  settings     UserSettings?
  categories   Category[]
  transactions Transaction[]
  debts        Debt[]

  @@map("users")
}

// =========================
// 1.5. Группы (Shared Spaces)
// =========================

model Group {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  joinCode  String   @unique @map("join_code")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  users        User[]
  transactions Transaction[]

  @@map("groups")
}

// =========================
// 2. Настройки пользователя
// =========================

enum ThemeMode {
  light
  dark
  system
}

enum Locale {
  ru
  kk
  en
}

model UserSettings {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @map("user_id") @db.Uuid
  themeMode   ThemeMode @default(system) @map("theme_mode")
  locale      Locale    @default(ru)
  currencyCode String   @default("USD") @map("currency_code")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// =========================
// 3. Категории
// =========================

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  name        String
  colorValue  BigInt    @map("color_value")
  iconCode    Int       @map("icon_code")
  isDefault   Boolean   @default(false) @map("is_default")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("categories")
}

// =========================
// 4. Транзакции
// =========================

enum TransactionType {
  income
  expense
}

enum RecurrenceInterval {
  daily
  weekly
  monthly
  none
}

model Transaction {
  id                String            @id @default(uuid()) @db.Uuid
  userId            String            @map("user_id") @db.Uuid
  categoryId        String?           @map("category_id") @db.Uuid
  type              TransactionType
  amount            Decimal           @db.Decimal(12, 2)
  currency          String            @default("USD")
  date              DateTime          @db.Timestamptz(6)
  note              String            @default("")
  isRecurring       Boolean           @default(false) @map("is_recurring")
  recurrenceInterval RecurrenceInterval @default(none) @map("recurrence_interval")
  nextOccurrence    DateTime?         @map("next_occurrence") @db.Timestamptz(6)
  isPinned          Boolean           @default(false) @map("is_pinned")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Groups
  groupId           String?           @map("group_id") @db.Uuid
  group             Group?            @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // Relations
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, date(sort: Desc)])
  @@index([userId, categoryId])
  @@index([userId, type])
  @@map("transactions")
}

// =========================
// 5. Долги и кредиты
// =========================

model Debt {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  type            String
  creditorName    String   @map("creditor_name")
  totalAmount     Decimal  @db.Decimal(12, 2) @map("total_amount")
  remainingAmount Decimal  @db.Decimal(12, 2) @map("remaining_amount")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("debts")
}

// =========================
// 6. Уведомления
// =========================

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  body      String
  target    String   @default("all")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("notifications")
}
